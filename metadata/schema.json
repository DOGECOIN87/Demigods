{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Demigods Token Metadata",
  "type": "object",
  "required": ["name", "description", "image", "token_id", "attributes", "trait_signature"],
  "properties": {
    "name": {"type": "string"},
    "description": {"type": "string"},
    "image": {"type": "string"},
    "token_id": {"type": "integer", "minimum": 1, "maximum": 777},
    "trait_signature": {"type": "string"},
    "attributes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["trait_type", "value", "source_file"],
        "properties": {
          "trait_type": {"type": "string"},
          "value": {"type": "string"},
          "source_file": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
